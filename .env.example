# Flask
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-characters
DEBUG=False
PORT=5000

# Claude API (Required)
ANTHROPIC_API_KEY=xxxx

# Notion (Optional - for team collaboration)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxx
NOTION_BRIEF_DB_ID=
NOTION_BLOG_DB_ID=
NOTION_SOCIAL_DB_ID=
NOTION_LEADS_DB_ID=
NOTION_METRICS_DB_ID=

# Supabase (Optional - for persistent storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Zapier (Optional - for Supabase to Notion sync)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/

# Railway
PORT=5000
